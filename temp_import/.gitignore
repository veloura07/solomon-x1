# Soloman X .gitignore

# Dependencies
/node_modules
/.pnp
.pnp.js

# Rust
/target
**/Cargo.lock

# Python
__pycache__
*.py[cod]
*$py.class
*.pyo
*.pyd
*.pyc
*.pyc
*.cpython-*
*.pyc
.venv
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Electron
/dist
/node_modules

# Logs
*.log
logs/

# Runtime data
/pids
/*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
/lib-cov

# Coverage directory used by tools like istanbul
/coverage
/.nyc_output

# Grunt intermediate storage (https://gruntjs.com/)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiler intermediate files
.obj
/*.obj
*.exe
*.exe
*.dll
*.dll
*.so
*.so
*.a
*.a
*.lib
*.lib

# Memory dumps
*.dmp
*.dmp

# OS generated files
.DS_Store
._DS_Store
Thumbs.db
Thumbs.db
ehthumbs.db
ehthumbs.db
Desktop.ini
Desktop.ini

# Application secrets
.env
.env.*
! .env.example

# Sealed tokens and keys (should never be committed)
/data/**/boot_token
/data/**/identity_keypair
/data/**/config.toml

# Soloman X specific
/solomon-x.log
/solomon-x.pid